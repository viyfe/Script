        {
          "id": "NGA_UA",
          "name": "自定义 User-Agent",
          "val": "Nga_Official/90409",
          "type": "text",
          "desc": "如果不懂，请保持默认即可。"
        }
      ],
      "author": "@viyfe",
      "repo": "https://github.com/viyfe/Script",
      "script": "https://raw.githubusercontent.com/viyfe/Script/refs/heads/main/nga_signin.js",
