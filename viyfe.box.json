    },
    {
      "id": "df_forum_checkin",
      "name": "DF 论坛签到",
      "keys": [
        "DF_DeepfloodHeaders"
      ],
      "settings": [
        {
          "id": "DF_DeepfloodHeaders",
          "name": "DF 请求头数据",
          "val": "",
          "type": "textarea",
