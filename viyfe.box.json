          "placeholder": "{\"Cookie\":\"...\", \"refract-sign\":\"...\"}"
        }
      ],
      "author": "@viyfe",
      "repo": "https://github.com/viyfe/Script",
      "icons": [
        "https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/author/ZenMoFeiShi.png",
        "https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/author/ZenMoFeiShi.png"
      ]
    },
    {
      "id": "nga_signin",
      "name": "NGA 论坛签到",
      "keys": [
        "NGA_CREDENTIALS",
        "NGA_UA"
