# RainViewer Pro Unlock Snippet
# 作用：解锁 RainViewer 实时雷达高级功能及去广告
# 适用：Quantumult X

[rewrite_local]
# 拦截双域名验证
^https?:\/\/(api\.revenuecat\.com\/v1\/subscribers|api\.rainviewer\.com\/mobile\/purchases\/ios\/actual) url script-response-body https://raw.githubusercontent.com/viyfe/Script/refs/heads/main/rainviewer.js

[mitm]
hostname = api.revenuecat.com, api.rainviewer.com
