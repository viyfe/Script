# 喵小乐 (MiaoXiaoLe) 终极解锁 Snippet
# 修复 Dart 引擎绕过圈叉重写的问题

[filter_local]
# 核心：拦截 UDP，强制 Dart 引擎降级至 TCP，使其能够被重写劫持
host, api.miaoxiaole.com, reject, udp

[rewrite_local]
# 放宽正则，覆盖所有 /book/ 下的接口
^https?:\/\/api\.miaoxiaole\.com\/book\/.* url script-response-body https://raw.githubusercontent.com/viyfe/Script/refs/heads/main/miaoxiaole_vip.js

[mitm]
hostname = api.miaoxiaole.com
